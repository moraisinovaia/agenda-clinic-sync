# =====================================
# Supabase (frontend + Edge Functions)
# =====================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# =====================================
# Edge Function: llm-agent-api
# =====================================
# Header x-api-key esperado em toda requisicao (validado em index.ts)
N8N_API_KEY=

# OpenAI (usado pela fase EXTRACT do /chat)
OPENAI_API_KEY=
# Opcional. Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Quando "true", requisicoes sem escopo de medico (allowed_doctor_ids/doctor_scope
# vazios) sao bloqueadas em vez de abrir todos os medicos do tenant.
# Default: nao definido (fail-open, comportamento atual). Ativar apenas apos
# garantir que o n8n sempre envia o escopo de medico do canal.
LLM_SCOPE_STRICT=

# =====================================
# n8n workflows (variaveis usadas pelos fluxos)
# =====================================
# Endpoint da llm-agent-api (projeto agenda-clinic-sync)
LLM_AGENT_API_URL=
# Mesmo valor de N8N_API_KEY
LLM_AGENT_API_KEY=

# Evolution API (WhatsApp) - URL base sem barra final
EVOLUTION_API_URL=

# Projeto Supabase do inovaia-platform (conversas/canais WhatsApp)
INOVAIA_SUPABASE_URL=
INOVAIA_SERVICE_ROLE_KEY=
