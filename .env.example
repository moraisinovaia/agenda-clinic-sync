# =====================================
# Supabase (frontend + Edge Functions)
# =====================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# =====================================
# Edge Function: llm-agent-api
# =====================================

# ── Auth multi-tenant ─────────────────────────────────────────────────────
# [F1.1] Cada tenant deve ter sua própria key registrada em `api_keys`. Use
# `_tests/scripts/generate-api-key.ts` para gerar keys novas.
#
# N8N_API_KEY (legacy/admin global) é mantido pra:
#   - Dr. Marcelo durante migração (dev/staging)
#   - Endpoints admin (/metrics global, ad-hoc /validate-config cross-tenant)
#   - Operações de manutenção
# Plano: depois que todos os tenants migrarem pra api_keys, remover.
N8N_API_KEY=

# ── OpenAI (chat handler) ─────────────────────────────────────────────────
OPENAI_API_KEY=
# Default: gpt-4o-mini. Trocar afeta CUSTO ($0.15/1M in vs gpt-4o $2.5/1M).
OPENAI_MODEL=gpt-4o-mini

# ── Comportamento ─────────────────────────────────────────────────────────
# Quando "true", requisições sem escopo de medico (allowed_doctor_ids/doctor_scope
# vazios) são bloqueadas em vez de abrir todos os medicos do tenant.
# Default: não definido (fail-open). Ativar após garantir que n8n sempre envia escopo.
LLM_SCOPE_STRICT=

# ── Rate limiting [F1.4 + H3] ─────────────────────────────────────────────
# Token bucket por cliente_id (in-memory) + Postgres counter cross-instance.
# In-memory zera no cold-start; Postgres é autoritativo no /chat (caro).
# Defaults: 60 req/min, burst 20.
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_BURST=20

# ── Daily cost guard [Sprint 7] ───────────────────────────────────────────
# Cap atômico de calls OpenAI/total por tenant (Postgres counter, reset UTC).
# Defaults conservadores: cobre clínica média (~3000 msg/dia) com folga.
QUOTA_OPENAI_PER_DAY=5000
QUOTA_TOTAL_PER_DAY=50000

# ── Circuit breaker OpenAI [F2.1 + H2] ────────────────────────────────────
# Per-tenant. Abre após N falhas, cooldown T ms. Half-open testa 1 trial.
BREAKER_FAILURES=5
BREAKER_COOLDOWN_MS=30000

# ── Cache de configuração ─────────────────────────────────────────────────
# config.ts usa CACHE_TTL_MS=60_000 hardcoded. Mudança em business_rules
# aparece em até 60s por instance. Sem hot-invalidation cross-instance.

# =====================================
# n8n workflows (variáveis usadas pelos fluxos)
# =====================================
# Endpoint da llm-agent-api (projeto agenda-clinic-sync)
LLM_AGENT_API_URL=
# API key do n8n — usar a tenant-bound (`api_keys.key_hash`), não a global
LLM_AGENT_API_KEY=

# Evolution API (WhatsApp) - URL base sem barra final
EVOLUTION_API_URL=

# Projeto Supabase do inovaia-platform (conversas/canais WhatsApp)
INOVAIA_SUPABASE_URL=
INOVAIA_SERVICE_ROLE_KEY=

# =====================================
# Procedimento de rotação de API key [F8.3]
# =====================================
#
# Pra ROTACIONAR a key de um tenant em produção SEM downtime:
#
#   1. Gerar nova key via:
#        SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=... \
#          deno run --allow-all \
#          supabase/functions/llm-agent-api/_tests/scripts/generate-api-key.ts \
#          <cliente_id> "n8n-prod-rotated-2026-05"
#      → A nova key aparece UMA VEZ no terminal. Copie pro 1Password.
#
#   2. Atualizar o n8n do tenant (env LLM_AGENT_API_KEY) pra a nova key.
#      Os 2 hash registros (antigo + novo) ficam ATIVOS simultâneamente —
#      nada quebra durante a transição.
#
#   3. Após confirmar que n8n está usando a nova key (ver `last_used_at` na
#      tabela api_keys), revogar a antiga:
#        UPDATE api_keys SET ativo=false, revoked_at=now()
#         WHERE id='<id-da-key-antiga>';
#
# Para REVOGAR EMERGENCIAL (chave vazou):
#   UPDATE api_keys SET ativo=false, revoked_at=now() WHERE id='<id>';
#   → o middleware passa a rejeitar a key imediatamente (próxima request).
