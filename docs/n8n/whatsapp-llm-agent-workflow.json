        "jsonBody": "={\n  \"cliente_id\": \"{{ $json.cliente_id }}\",\n  \"config_id\": \"{{ $json.config_id }}\",\n  \"mensagem\": {{ JSON.stringify($json.mensagem) }},\n  \"estado_atual\": \"{{ $json.estado_atual }}\",\n  \"dados_coletados\": {{ JSON.stringify($json.dados_coletados) }},\n  \"historico_contexto\": {{ JSON.stringify($json.historico_contexto) }}\n}",
