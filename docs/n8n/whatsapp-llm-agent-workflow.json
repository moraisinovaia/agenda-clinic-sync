    {
      "parameters": {
        "jsCode": "// Extrai dados do payload Evolution v2.\n// Espera: { data: { key: { remoteJid }, message: { conversation | extendedTextMessage.text } } }\n// Filtra mensagens enviadas pelo bot (fromMe=true) — só processa do paciente.\n\nconst item = $input.first().json;\nconst data = item.data || item;\n\nconst fromMe = data?.key?.fromMe === true;\nif (fromMe) {\n  return [];  // descarta, não responde a si mesmo\n}\n\nconst remoteJid = data?.key?.remoteJid || '';\nconst telefone = remoteJid.replace(/@s\\.whatsapp\\.net$/, '').replace(/@c\\.us$/, '');\n\nconst mensagem =\n  data?.message?.conversation ||\n  data?.message?.extendedTextMessage?.text ||\n  data?.message?.imageMessage?.caption ||\n  '';\n\nif (!telefone || !mensagem) {\n  return [];\n}\n\nreturn [{\n  json: {\n    telefone,\n    session_id: telefone,\n    mensagem: String(mensagem).trim(),\n    cliente_id: $input.first().json.cliente_id,\n    config_id: $input.first().json.config_id,\n    evolution_instance: $input.first().json.evolution_instance,\n  },\n}];"
      },
      "id": "extract-payload",
      "name": "Extract payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 340]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT estado_atual, dados_coletados, historico_contexto, lock_conversa, modo_atendimento\nFROM public.n8n_status_atendimento\nWHERE session_id = $1 AND cliente_id = $2\nLIMIT 1;",
        "additionalFields": {
          "queryParams": "={{ $json.session_id }},{{ $json.cliente_id }}"
        }
      },
      "id": "load-state",
      "name": "Load state",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [900, 340],
      "credentials": {
        "postgres": {
          "id": "PLACEHOLDER_POSTGRES_CRED_ID",
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Merge state do DB com payload. Se conversa nova → defaults.\n// Bloqueia se lock_conversa=true (humano assumiu via Chatwoot).\n\nconst payload = $('Extract payload').first().json;\nconst row = $input.first().json;\n\n// Sem row = conversa nova\nconst hasState = row && row.session_id !== undefined ? true : Object.keys(row || {}).length > 0;\n\nif (hasState && row.lock_conversa === true) {\n  return [{\n    json: { ...payload, _skip_llm: true, _reason: 'lock_conversa' },\n  }];\n}\n\nreturn [{\n  json: {\n    ...payload,\n    estado_atual: row?.estado_atual || 'inicio',\n    dados_coletados: row?.dados_coletados || {},\n    historico_contexto: row?.historico_contexto || [],\n  },\n}];"
      },
      "id": "merge-state",
      "name": "Merge state",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 340]
    },
