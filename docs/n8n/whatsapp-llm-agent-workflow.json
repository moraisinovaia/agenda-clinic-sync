    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO public.n8n_status_atendimento (\n  session_id, cliente_id, config_id,\n  estado_atual, dados_coletados, historico_contexto, updated_at\n) VALUES ($1, $2, $3, $4, $5::jsonb, $6::jsonb, now())\nON CONFLICT (session_id, cliente_id) DO UPDATE SET\n  config_id          = EXCLUDED.config_id,\n  estado_atual       = EXCLUDED.estado_atual,\n  dados_coletados    = EXCLUDED.dados_coletados,\n  historico_contexto = EXCLUDED.historico_contexto,\n  updated_at         = now();",
        "additionalFields": {
          "queryParams": "={{ $('Merge state').first().json.session_id }},{{ $('Merge state').first().json.cliente_id }},{{ $('Merge state').first().json.config_id }},{{ $json.novo_estado }},{{ JSON.stringify($json.dados_coletados) }},{{ JSON.stringify($json.historico_contexto) }}"
        }
